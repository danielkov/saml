    {
      "method": "POST",
      "url": "/api/lambda/#{samlLambdaId}",
      "body": {
        "lambda": {
          "name": "saml-axum-demo SAML response populate",
          "type": "SAMLv2Populate",
          "enabled": true,
          "body": "function populate(samlResponse, user, registration) {\n  samlResponse.assertion.attributes['email'] = [user.email];\n  if (user.fullName) { samlResponse.assertion.attributes['displayName'] = [user.fullName]; }\n  if (user.firstName) { samlResponse.assertion.attributes['givenName'] = [user.firstName]; }\n  if (user.lastName) { samlResponse.assertion.attributes['sn'] = [user.lastName]; }\n  if (user.data && user.data.department) { samlResponse.assertion.attributes['department'] = [user.data.department]; }\n}\n"
        }
      }
    },

    {
      "method": "POST",
      "url": "/api/tenant/#{tenantId}",
      "body": {
        "tenant": {
          "name": "saml-demo",
          "issuer": "http://localhost:9011"
        }
      }
    },

    {
      "method": "POST",
      "url": "/api/application/#{applicationId}",
      "tenantId": "#{tenantId}",
      "body": {
        "application": {
          "name": "saml-axum-demo",
          "samlv2Configuration": {
            "enabled": true,
            "issuer": "saml-axum-demo",
            "audience": "saml-axum-demo",
            "authorizedRedirectURLs": [
              "http://localhost:3000/saml/acs"
            ],
            "callbackURL": "http://localhost:3000/saml/acs",
            "keyId": "#{samlSigningKeyId}",
            "defaultVerificationKeyId": "#{samlSpVerifyKeyId}",
            "requireSignedRequests": true,
            "xmlSignatureC14nMethod": "exclusive_with_comments",
            "xmlSignatureLocation": "Assertion",
            "logout": {
              "behavior": "AllParticipants",
              "singleLogout": {
                "enabled": true,
                "url": "http://localhost:3000/saml/slo",
                "xmlSignatureC14nMethod": "exclusive_with_comments"
              }
            }
          },
          "lambdaConfiguration": {
            "samlv2PopulateId": "#{samlLambdaId}"
          },
          "loginConfiguration": {
            "allowTokenRefresh": false,
            "generateRefreshTokens": false,
            "requireAuthentication": true
          }
        }
      }
    },

    {
      "method": "POST",
      "url": "/api/user/registration",
      "body": {
        "user": {
          "email": "#{adminEmail}",
          "password": "#{adminPassword}",
          "firstName": "Admin",
          "lastName": "User"
        },
        "registration": {
          "applicationId": "#{FUSIONAUTH_APPLICATION_ID}",
          "roles": ["admin"]
        }
      }
    },

    {
      "method": "POST",
      "url": "/api/user/registration",
      "tenantId": "#{tenantId}",
      "body": {
        "user": {
          "email": "#{userEmail}",
          "password": "#{userPassword}",
          "firstName": "Alice",
          "lastName": "Anderson",
          "fullName": "Alice Anderson",
          "data": {
            "department": "platform"
          }
        },
        "registration": {
          "applicationId": "#{applicationId}",
          "username": "alice"
        }
      }
    }
