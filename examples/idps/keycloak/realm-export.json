{
  "id": "saml-demo",
  "realm": "saml-demo",
  "enabled": true,
  "displayName": "SAML Demo Realm",
  "displayNameHtml": "<span>SAML Demo Realm</span>",
  "registrationAllowed": false,
  "resetPasswordAllowed": false,
  "rememberMe": false,
  "verifyEmail": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "permanentLockout": false,
  "sslRequired": "none",
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "users": [
    {
      "username": "alice",
      "enabled": true,
      "emailVerified": true,
      "email": "alice@saml-demo.test",
      "firstName": "Alice",
      "lastName": "Anderson",
      "attributes": {
        "displayName": ["Alice Anderson"],
        "department": ["platform"]
      },
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "realmRoles": [
        "default-roles-saml-demo"
      ]
    }
  ],
  "clients": [
    {
      "clientId": "saml-axum-demo",
      "name": "saml-axum-demo",
      "description": "Axum-based Service Provider demo for the saml crate.",
      "enabled": true,
      "protocol": "saml",
      "publicClient": false,
      "frontchannelLogout": true,
      "baseUrl": "http://localhost:3000/",
      "redirectUris": [
        "http://localhost:3000/saml/acs",
        "http://localhost:3000/*"
      ],
      "adminUrl": "http://localhost:3000/",
      "attributes": {
        "saml.assertion.signature": "true",
        "saml.server.signature": "false",
        "saml.client.signature": "true",
        "saml.authnstatement": "true",
        "saml.force.post.binding": "true",
        "saml.encrypt": "false",
        "saml.signature.algorithm": "RSA_SHA256",
        "saml_signature_canonicalization_method": "http://www.w3.org/2001/10/xml-exc-c14n#",
        "saml_assertion_consumer_url_post": "http://localhost:3000/saml/acs",
        "saml_assertion_consumer_url_redirect": "http://localhost:3000/saml/acs",
        "saml_single_logout_service_url_post": "http://localhost:3000/saml/slo",
        "saml_name_id_format": "email",
        "saml.signing.certificate": ""
      },
      "protocolMappers": [
        {
          "name": "email",
          "protocol": "saml",
          "protocolMapper": "saml-user-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "email",
            "friendly.name": "mail",
            "attribute.name": "urn:oid:0.9.2342.19200300.100.1.3",
            "attribute.nameformat": "URI Reference"
          }
        },
        {
          "name": "displayName",
          "protocol": "saml",
          "protocolMapper": "saml-user-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "displayName",
            "friendly.name": "displayName",
            "attribute.name": "urn:oid:2.16.840.1.113730.3.1.241",
            "attribute.nameformat": "URI Reference"
          }
        },
        {
          "name": "givenName",
          "protocol": "saml",
          "protocolMapper": "saml-user-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "firstName",
            "friendly.name": "givenName",
            "attribute.name": "urn:oid:2.5.4.42",
            "attribute.nameformat": "URI Reference"
          }
        },
        {
          "name": "surname",
          "protocol": "saml",
          "protocolMapper": "saml-user-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "lastName",
            "friendly.name": "sn",
            "attribute.name": "urn:oid:2.5.4.4",
            "attribute.nameformat": "URI Reference"
          }
        },
        {
          "name": "department",
          "protocol": "saml",
          "protocolMapper": "saml-user-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "department",
            "friendly.name": "department",
            "attribute.name": "department",
            "attribute.nameformat": "Basic"
          }
        }
      ]
    }
  ]
}
