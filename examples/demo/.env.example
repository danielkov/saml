# Local-only overrides for the consolidated saml-demo. Copy to `.env`
# (which is gitignored) and tweak as needed; everything here is optional
# because providers.toml ships sensible defaults that match the live
# cloud tenants and the local IdP stacks in `examples/idps/`.

# Bind port for the SP. Must match the ACS URL pinned on every IdP.
SAML_DEMO_PORT="3000"

# Public base URL of the SP. The SP composes `/saml/acs` and `/saml/slo`
# off this. Do NOT change this if you're testing against the live cloud
# tenants — they're pinned to http://localhost:3000.
SAML_DEMO_BASE_URL="http://localhost:3000"

# SP EntityID. Pinned across every IdP's app/client config; changing this
# will break the audience check on every Response.
SAML_DEMO_SP_ENTITY_ID="saml-axum-demo"

# Path to providers.toml. Defaults to `config/providers.toml` relative
# to the binary's working directory, falling back to a baked-in copy.
# SAML_DEMO_PROVIDERS_TOML="config/providers.toml"

# Per-provider metadata URL overrides. Use these to point at a private
# Zitadel or a non-default Keycloak port without editing providers.toml.
# The naming is SAML_DEMO_PROVIDER_<UPPER_ID>_METADATA_URL.
# SAML_DEMO_PROVIDER_KEYCLOAK_METADATA_URL="http://localhost:8080/realms/saml-demo/protocol/saml/descriptor"
# SAML_DEMO_PROVIDER_AUTHENTIK_METADATA_URL="http://localhost:9000/application/saml/saml-axum-demo/metadata/"
# SAML_DEMO_PROVIDER_FUSIONAUTH_METADATA_URL="http://localhost:9011/samlv2/metadata/e9fdb985-9173-4e01-9d73-ac2d60d1dc8e"
# SAML_DEMO_PROVIDER_ZITADEL_METADATA_URL="https://saml-demo-2ubgsa.us1.zitadel.cloud/saml/v2/metadata"
# SAML_DEMO_PROVIDER_AUTH0_METADATA_URL="https://dev-x8koaq5b27hij85j.us.auth0.com/samlp/metadata/5gRkInIpQbXpu8TcYfuXCmEDc80c8rnF"
# SAML_DEMO_PROVIDER_DESCOPE_METADATA_URL="https://api.descope.com/v1/auth/saml/idp/metadata?app=P3ELzaM575ix5hTMvT5VxTtfZ3ZB-saml_axum_demo"
# SAML_DEMO_PROVIDER_ASGARDEO_METADATA_URL="https://api.asgardeo.io/t/samldemo/identity/metadata/saml2"

# Tracing filter.
RUST_LOG="info,tower_http=info"
