# Local-only overrides for the standalone Rust IdP example. Copy to `.env`
# (gitignored) and tweak as needed; defaults match the SP demo's expectations.

# Bind port for the IdP. The SP demo's providers.toml entry for "rust-idp"
# expects metadata at http://localhost:3001/metadata.
SAML_IDP_PORT="3001"

# Public base URL of the IdP. Used to compose SSO, SLO, and ArtifactResolution
# endpoint URLs in the metadata.
SAML_IDP_BASE_URL="http://localhost:3001"

# IdP EntityID advertised in the issued Assertion's Issuer element.
SAML_IDP_ENTITY_ID="http://localhost:3001/saml/idp"

# Path to users.toml. Defaults to `config/users.toml` relative to the binary's
# working directory; falls back to the baked-in copy.
# SAML_IDP_USERS_TOML="config/users.toml"

# Path to sps.toml. Same shape as SAML_IDP_USERS_TOML.
# SAML_IDP_SPS_TOML="config/sps.toml"

# Per-SP metadata URL override. Use this in tests to point the IdP at a
# free-port demo SP without editing sps.toml. Naming is
# SAML_IDP_SP_<UPPER_ENTITY_ID>_METADATA_URL with `-`/`:` mapped to `_`.
# SAML_IDP_SP_SAML_AXUM_DEMO_METADATA_URL="http://localhost:3000/metadata"

# Tracing filter.
RUST_LOG="info,tower_http=info"
